{
  "name": "wau-sdk",
  "version": "1.3.2",
  "description": "Official TypeScript / JavaScript SDK for WAU-core-kernel \u2014 AI agent dispatch",
  "license": "MIT",
  "author": "youhaoxi <liuhaoshi888@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XploreAlpha/wau-typescript-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/XploreAlpha/wau-typescript-sdk/issues"
  },
  "homepage": "https://github.com/XploreAlpha/wau-typescript-sdk#readme",
  "keywords": [
    "wau",
    "ai-agents",
    "sdk",
    "dispatch",
    "kernel",
    "typescript",
    "node"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./wau": {
      "import": "./dist/wau/index.js",
      "types": "./dist/wau/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --check src/ tests/",
    "format:fix": "prettier --write src/ tests/",
    "typecheck": "tsc --noEmit",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "axios": "^1.7.0",
    "jsonwebtoken": "^9.0.0",
    "long": "^5.2.0",
    "@slack/web-api": "^7.5.0",
    "@slack/socket-mode": "^1.3.0",
    "@larksuiteoapi/node-sdk": "^1.18.0",
    "dingtalk-stream": "^1.0.0",
    "imap": "^0.8.19",
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "nock": "^13.5.0",
    "prettier": "^3.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
